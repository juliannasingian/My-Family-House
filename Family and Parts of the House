      </div>
    </main>

    <!-- Custom On-Screen Interactive Feedback Messages -->
    <div id="feedbackToast" class="absolute bottom-16 left-1/2 transform -translate-x-1/2 bg-green-500 text-white px-8 py-3 rounded-full text-lg font-bold shadow-lg opacity-0 transition-opacity duration-300 pointer-events-none flex items-center space-x-2 z-50">
      <span>Yay! Super Job!</span>
    </div>

    <!-- Celebration/Game Over Screen Overlay (Hidden by default) -->
    <div id="finishOverlay" class="absolute inset-0 bg-purple-900/90 backdrop-blur-md flex flex-col items-center justify-center text-white p-6 hidden z-50">
      <div class="bg-white text-purple-900 p-8 rounded-3xl max-w-md text-center border-8 border-yellow-400 shadow-2xl space-y-6 transform scale-90 transition-transform duration-500" id="victoryCard">
        
        <!-- Big Happy Sun & Family -->
        <div class="flex justify-center">
          <svg class="w-32 h-32 animate-spin" style="animation-duration: 20s;" viewBox="0 0 100 100">
            <circle cx="50" cy="50" r="20" fill="#fbbf24" stroke="#f59e0b" stroke-width="3" />
            <!-- Sunrays -->
            <path d="M 50 10 L 50 25 M 50 75 L 50 90 M 10 50 L 25 50 M 75 50 L 90 50 M 22 22 L 32 32 M 68 68 L 78 78 M 22 68 L 32 62 M 68 22 L 58 32" stroke="#f59e0b" stroke-width="6" stroke-linecap="round" />
          </svg>
        </div>

        <h2 class="text-4xl font-extrabold text-pink-500 tracking-wide">Awesome Work!</h2>
        <p class="text-lg font-medium text-gray-700">You built the house, helped the family, and organized the rooms! You are a superstar! 🌟</p>
        
        <!-- Final Score Display -->
        <div class="bg-yellow-50 py-3 px-6 rounded-2xl border-4 border-yellow-300 inline-block">
          <span class="text-2xl font-bold text-yellow-600">Final Stars: <span id="finalScore">0</span> / 12 ⭐</span>
        </div>

        <!-- Restart Button -->
        <button onclick="restartGame()" class="w-full bg-gradient-to-r from-green-400 to-emerald-500 hover:from-green-500 hover:to-emerald-600 text-white font-extrabold text-2xl py-4 rounded-2xl shadow-lg border-b-8 border-emerald-700 transform active:scale-95 transition-all">
          Play Again! 🔄
        </button>
      </div>
    </div>

    <!-- Active Canvas for Level Complete Confetti -->
    <canvas id="confettiCanvas" class="absolute inset-0 pointer-events-none hidden z-40"></canvas>

    <!-- Bottom Instruction Bar with Help Text -->
    <footer class="bg-purple-100 p-3 text-center border-t-4 border-purple-200">
      <p id="footerInstructions" class="text-purple-900 font-extrabold text-sm md:text-base tracking-wide">
        Drag the roof to the top of the house outline!
      </p>
    </footer>

  </div>

  <script>
    /* =========================================
       AUDIO ENGINE (Web Audio API Synthesizer)
       ========================================= */
    let audioCtx = null;
    let bMusicNode = null;
    let isMusicPlaying = false;
    let musicInterval = null;

    function initAudio() {
      if (!audioCtx) {
        audioCtx = new (window.AudioContext || window.webkitAudioContext)();
      }
    }

    // Play synthesized sound effects
    function playSound(type) {
      initAudio();
      if (!audioCtx) return;

      const osc = audioCtx.createOscillator();
      const gain = audioCtx.createGain();
      osc.connect(gain);
      gain.connect(audioCtx.destination);

      const now = audioCtx.currentTime;

      if (type === 'correct') {
        // High, happy chime (two rising notes)
        osc.type = 'triangle';
        osc.frequency.setValueAtTime(523.25, now); // C5
        osc.frequency.setValueAtTime(659.25, now + 0.1); // E5
        osc.frequency.setValueAtTime(783.99, now + 0.2); // G5
        gain.gain.setValueAtTime(0.15, now);
        gain.gain.exponentialRampToValueAtTime(0.01, now + 0.4);
        osc.start(now);
        osc.stop(now + 0.45);
      } else if (type === 'incorrect') {
        // Low, sad bonk
        osc.type = 'sawtooth';
        osc.frequency.setValueAtTime(180, now);
        osc.frequency.exponentialRampToValueAtTime(110, now + 0.25);
        gain.gain.setValueAtTime(0.12, now);
        gain.gain.exponentialRampToValueAtTime(0.01, now + 0.3);
        osc.start(now);
        osc.stop(now + 0.3);
      } else if (type === 'level_up') {
        // Grand winning flourish
        const notes = [261.63, 329.63, 392.00, 523.25, 659.25, 783.99, 1046.50]; // C4 to C6 arpeggio
        notes.forEach((freq, idx) => {
          const singleOsc = audioCtx.createOscillator();
          const singleGain = audioCtx.createGain();
          singleOsc.connect(singleGain);
          singleGain.connect(audioCtx.destination);
          singleOsc.type = 'sine';
          singleOsc.frequency.setValueAtTime(freq, now + (idx * 0.08));
          singleGain.gain.setValueAtTime(0.1, now + (idx * 0.08));
          singleGain.gain.exponentialRampToValueAtTime(0.01, now + (idx * 0.08) + 0.3);
          singleOsc.start(now + (idx * 0.08));
          singleOsc.stop(now + (idx * 0.08) + 0.35);
        });
      }
    }

    // Gentle kindergarten background melody loop
    function startBackgroundMusic() {
      initAudio();
      if (!audioCtx) return;

      isMusicPlaying = true;
      document.getElementById('musicOnIcon').classList.add('hidden');
      document.getElementById('musicOffIcon').classList.remove('hidden');

      const melody = [
        261.63, 293.66, 329.63, 349.23, 392.00, 349.23, 329.63, 293.66, // C, D, E, F, G, F, E, D
        329.63, 349.23, 392.00, 440.00, 493.88, 440.00, 392.00, 349.23  // E, F, G, A, B, A, G, F
      ];
      let noteIndex = 0;

      musicInterval = setInterval(() => {
        if (!isMusicPlaying || !audioCtx) return;
        
        const now = audioCtx.currentTime;
        const osc = audioCtx.createOscillator();
        const filter = audioCtx.createBiquadFilter();
        const gain = audioCtx.createGain();

        osc.connect(filter);
        filter.connect(gain);
        gain.connect(audioCtx.destination);

        osc.type = 'triangle'; // Soft kindergarten tone
        osc.frequency.setValueAtTime(melody[noteIndex], now);
        
        filter.type = 'lowpass';
        filter.frequency.setValueAtTime(1000, now);

        gain.gain.setValueAtTime(0.03, now); // Quiet background volume
        gain.gain.exponentialRampToValueAtTime(0.001, now + 0.45);

        osc.start(now);
        osc.stop(now + 0.5);

        noteIndex = (noteIndex + 1) % melody.length;
      }, 500);
    }

    function stopBackgroundMusic() {
      isMusicPlaying = false;
      document.getElementById('musicOnIcon').classList.remove('hidden');
      document.getElementById('musicOffIcon').classList.add('hidden');
      if (musicInterval) {
        clearInterval(musicInterval);
        musicInterval = null;
      }
    }

    function toggleMusic() {
      if (isMusicPlaying) {
        stopBackgroundMusic();
      } else {
        startBackgroundMusic();
      }
    }


    /* =========================================
       SPEECH OVER ENGINE (Kindergarten Helpers)
       ========================================= */
    function speakInstructions() {
      const currentText = document.getElementById('footerInstructions').innerText;
      if ('speechSynthesis' in window) {
        // Cancel any active utterance
        window.speechSynthesis.cancel();
        
        const utterance = new SpeechSynthesisUtterance(currentText);
        utterance.rate = 0.85; // Speak slower for kindergarten learners
        utterance.pitch = 1.2; // Slightly higher/friendly pitch
        window.speechSynthesis.speak(utterance);
      }
    }


    /* =========================================
       GAME STATE & LEVEL SYSTEM
       ========================================= */
    let currentLevel = 1;
    let score = 0;
    const levelGoals = {
      1: 4, // 4 parts of the house
      2: 4, // 4 family members
      3: 4  // 4 room objects
    };
    let currentLevelMatches = 0;

    // Level configs for instruction reading
    const levelInstructions = {
      1: "Let's build our happy house! Drag the roof, walls, door, and window to their matching grey shadows!",
      2: "Great building! Now help our family find their favorite rooms! Drag Mom, Dad, Sister, and Puppy home!",
      3: "Let's organize the rooms! Drag the Bed, Frying Pan, Teddy Bear, and Watering Can to the correct rooms!"
    };

    function updateScore(points) {
      score += points;
      document.getElementById('scoreDisplay').innerText = score;
    }

    function showLevel(levelNum) {
      // Hide all levels
      document.getElementById('level1').classList.add('hidden');
      document.getElementById('level2').classList.add('hidden');
      document.getElementById('level3').classList.add('hidden');

      // Show requested level
      document.getElementById('level' + levelNum).classList.remove('hidden');
      currentLevel = levelNum;
      currentLevelMatches = 0;

      // Update instructions
      const targetInstruction = levelInstructions[levelNum];
      document.getElementById('footerInstructions').innerText = targetInstruction;
      const bubble = document.getElementById('hintBubble');
      if (levelNum === 1) bubble.innerText = "Let's build our happy house!";
      if (levelNum === 2) bubble.innerText = "Where do family members live?";
      if (levelNum === 3) bubble.innerText = "Match items to their rooms!";

      // Speak instructions automatically for seamless visual-auditory connection
      setTimeout(() => {
        speakInstructions();
      }, 500);
    }


    /* =========================================
       DRAG AND DROP HANDLER (Pointer Events)
       ========================================= */
    let activeDragElement = null;
    let dragStartX = 0;
    let dragStartY = 0;
    let initialLeft = 0;
    let initialTop = 0;

    function initDragAndDrop() {
      const draggables = document.querySelectorAll('.draggable');
      const dropzones = document.querySelectorAll('.dropzone');

      draggables.forEach(draggable => {
        draggable.addEventListener('pointerdown', onPointerDown);
      });
    }

    function onPointerDown(e) {
      // Prevent standard browser defaults (like highlighting)
      e.preventDefault();
      
      activeDragElement = e.currentTarget;
      activeDragElement.style.touchAction = 'none';

      // Record baseline coordinates
      const rect = activeDragElement.getBoundingClientRect();
      dragStartX = e.clientX;
      dragStartY = e.clientY;

      // Ensure the element has manual style positions if not set
      if (!activeDragElement.style.left) {
        activeDragElement.style.position = 'relative';
        activeDragElement.style.left = '0px';
        activeDragElement.style.top = '0px';
      }

      initialLeft = parseFloat(activeDragElement.style.left) || 0;
      initialTop = parseFloat(activeDragElement.style.top) || 0;

      // Set active pointer capture so drag is maintained outside target bounds
      activeDragElement.setPointerCapture(e.pointerId);
      activeDragElement.addEventListener('pointermove', onPointerMove);
      activeDragElement.addEventListener('pointerup', onPointerUp);
      activeDragElement.addEventListener('pointercancel', onPointerCancel);

      // Scale up element slightly for satisfying drag feedback
      activeDragElement.style.zIndex = "100";
      activeDragElement.style.transform = "scale(1.15)";
      activeDragElement.classList.add('shadow-xl');

      // Highlight target dropzone
      const targetId = activeDragElement.getAttribute('data-target');
      const dropzone = document.getElementById(targetId);
      if (dropzone) {
        dropzone.classList.add('dropzone-active');
      }
    }

    function onPointerMove(e) {
      if (!activeDragElement) return;

      const deltaX = e.clientX - dragStartX;
      const deltaY = e.clientY - dragStartY;

      activeDragElement.style.left = `${initialLeft + deltaX}px`;
      activeDragElement.style.top = `${initialTop + deltaY}px`;
    }

    function onPointerUp(e) {
      if (!activeDragElement) return;

      const targetId = activeDragElement.getAttribute('data-target');
      const dropzone = document.getElementById(targetId);
      
      // Remove visual helper indicators
      if (dropzone) {
        dropzone.classList.remove('dropzone-active');
      }

      // Check collision/intersection
      if (dropzone && isOverlapping(activeDragElement, dropzone)) {
        // Success Match!
        handleSuccess(activeDragElement, dropzone);
      } else {
        // Fail / Drop back
        handleFailure(activeDragElement);
      }

      cleanupPointerEvents(e);
    }

    function onPointerCancel(e) {
      handleFailure(activeDragElement);
      cleanupPointerEvents(e);
    }

    function cleanupPointerEvents(e) {
      if (activeDragElement) {
        activeDragElement.releasePointerCapture(e.pointerId);
        activeDragElement.removeEventListener('pointermove', onPointerMove);
        activeDragElement.removeEventListener('pointerup', onPointerUp);
        activeDragElement.removeEventListener('pointercancel', onPointerCancel);
        activeDragElement.style.transform = "";
        activeDragElement.classList.remove('shadow-xl');
        activeDragElement = null;
      }
    }

    // Geometry calculation to support high precision overlap matching
    function isOverlapping(el1, el2) {
      const rect1 = el1.getBoundingClientRect();
      const rect2 = el2.getBoundingClientRect();

      // Check if the center of element 1 is inside the bounding rectangle of element 2
      const el1Center = {
        x: rect1.left + rect1.width / 2,
        y: rect1.top + rect1.height / 2
      };

      return (
        el1Center.x >= rect2.left &&
        el1Center.x <= rect2.right &&
        el1Center.y >= rect2.top &&
        el1Center.y <= rect2.bottom
      );
    }

    /* =========================================
       SUCCESS / FAILURE INTERACTIONS
       ========================================= */
    function handleSuccess(element, dropzone) {
      playSound('correct');
      updateScore(1);

      // Trigger Confetti Pop on drop success
      triggerLocalConfetti(dropzone);

      // Disable dragging on completed element
      element.removeEventListener('pointerdown', onPointerDown);
      element.classList.remove('draggable', 'cursor-grab');
      element.classList.add('pop-success');
      
      // Style placement in dropzone
      element.style.position = "absolute";
      element.style.left = "50%";
      element.style.top = "50%";
      element.style.transform = "translate(-50%, -50%) scale(1.1)";
      element.style.zIndex = "10";
      
      // Put matched item inside the designated dropzone container
      dropzone.appendChild(element);
      dropzone.setAttribute('data-filled', 'true');

      // Visual feedback toast
      showToast("Wow! Excellent Match! 🌟");

      currentLevelMatches++;

      // Check if current level finished
      if (currentLevelMatches >= levelGoals[currentLevel]) {
        setTimeout(() => {
          advanceLevel();
        }, 1200);
      }
    }

    function handleFailure(element) {
      if (!element) return;
      
      playSound('incorrect');
      element.classList.add('shake-fail');
      showToast("Let's try again! You can do it! 💪");

      // Snap back to home position
      element.style.left = '0px';
      element.style.top = '0px';
      element.style.zIndex = "10";

      setTimeout(() => {
        element.classList.remove('shake-fail');
      }, 500);
    }

    function showToast(message) {
      const toast = document.getElementById('feedbackToast');
      toast.innerText = message;
      toast.style.opacity = "1";
      setTimeout(() => {
        toast.style.opacity = "0";
      }, 1500);
    }

    function advanceLevel() {
      playSound('level_up');
      triggerFullConfetti();

      if (currentLevel < 3) {
        showToast(`Level ${currentLevel} Clear! Get ready... 🚀`);
        setTimeout(() => {
          showLevel(currentLevel + 1);
        }, 1500);
      } else {
        // Game Completed
        setTimeout(() => {
          showFinishScreen();
        }, 1000);
      }
    }


    /* =========================================
       CELEBRATION / CONFETTI ENGINE
       ========================================= */
    const canvas = document.getElementById('confettiCanvas');
    const ctx = canvas.getContext('2d');
    let confettiParticles = [];
    let animationFrameId = null;

    function resizeCanvas() {
      canvas.width = canvas.parentElement.clientWidth;
      canvas.height = canvas.parentElement.clientHeight;
    }

    window.addEventListener('resize', resizeCanvas);

    class Confetti {
      constructor(x, y, color, isBurst = false) {
        this.x = x;
        this.y = y;
        this.color = color;
        this.size = Math.random() * 8 + 6;
        this.speedX = isBurst ? (Math.random() - 0.5) * 12 : (Math.random() - 0.5) * 4;
        this.speedY = isBurst ? (Math.random() - 0.5) * 12 - 5 : Math.random() * 3 + 2;
        this.rotation = Math.random() * 360;
        this.rotationSpeed = Math.random() * 4 - 2;
        this.opacity = 1;
      }

      update() {
        this.x += this.speedX;
        this.y += this.speedY;
        this.rotation += this.rotationSpeed;
        this.speedY += 0.08; // Gravity simulation
        this.opacity -= 0.012;
      }

      draw() {
        ctx.save();
        ctx.translate(this.x, this.y);
        ctx.rotate((this.rotation * Math.PI) / 180);
        ctx.fillStyle = this.color;
        ctx.globalAlpha = this.opacity;
        ctx.fillRect(-this.size / 2, -this.size / 2, this.size, this.size);
        ctx.restore();
      }
    }

    const colors = ['#f43f5e', '#3b82f6', '#10b981', '#f59e0b', '#ec4899', '#8b5cf6'];

    function triggerLocalConfetti(targetElement) {
      canvas.classList.remove('hidden');
      resizeCanvas();
      
      const rect = targetElement.getBoundingClientRect();
      const parentRect = canvas.getBoundingClientRect();
      const localX = (rect.left + rect.width / 2) - parentRect.left;
      const localY = (rect.top + rect.height / 2) - parentRect.top;

      for (let i = 0; i < 20; i++) {
        const randomColor = colors[Math.floor(Math.random() * colors.length)];
        confettiParticles.push(new Confetti(localX, localY, randomColor, true));
      }

      if (!animationFrameId) {
        animateConfetti();
      }
    }

    function triggerFullConfetti() {
      canvas.classList.remove('hidden');
      resizeCanvas();

      for (let i = 0; i < 100; i++) {
        const randomColor = colors[Math.floor(Math.random() * colors.length)];
        confettiParticles.push(new Confetti(Math.random() * canvas.width, -10, randomColor, false));
      }

      if (!animationFrameId) {
        animateConfetti();
      }
    }

    function animateConfetti() {
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      confettiParticles.forEach((particle, idx) => {
        particle.update();
        particle.draw();
        if (particle.opacity <= 0 || particle.y > canvas.height) {
          confettiParticles.splice(idx, 1);
        }
      });

      if (confettiParticles.length > 0) {
        animationFrameId = requestAnimationFrame(animateConfetti);
      } else {
        canvas.classList.add('hidden');
        cancelAnimationFrame(animationFrameId);
        animationFrameId = null;
      }
    }


    /* =========================================
       FINISH / RESET STATE MANAGEMENT
       ========================================= */
    // Capture home template layouts to completely restore interactive divs upon restart
    let initialLvl1HTML = "";
    let initialLvl2HTML = "";
    let initialLvl3HTML = "";

    window.onload = function() {
      initialLvl1HTML = document.getElementById('level1').innerHTML;
      initialLvl2HTML = document.getElementById('level2').innerHTML;
      initialLvl3HTML = document.getElementById('level3').innerHTML;

      initDragAndDrop();
      showLevel(1);

      // Start quiet musical ambiance automatically (most modern browsers require user action first;
      // if blocked, the play button handles triggering context manually)
      document.body.addEventListener('click', () => {
        if (!isMusicPlaying && !audioCtx) {
          startBackgroundMusic();
        }
      }, { once: true });
    };

    function showFinishScreen() {
      document.getElementById('finalScore').innerText = score;
      const overlay = document.getElementById('finishOverlay');
      overlay.classList.remove('hidden');
      setTimeout(() => {
        document.getElementById('victoryCard').style.transform = "scale(1)";
      }, 50);
    }

    function restartGame() {
      score = 0;
      document.getElementById('scoreDisplay').innerText = score;
      document.getElementById('finishOverlay').classList.add('hidden');
      document.getElementById('victoryCard').style.transform = "scale(0.9)";
      
      // Reload pure DOM states
      document.getElementById('level1').innerHTML = initialLvl1HTML;
      document.getElementById('level2').innerHTML = initialLvl2HTML;
      document.getElementById('level3').innerHTML = initialLvl3HTML;

      // Reattach core draggable events
      initDragAndDrop();
      showLevel(1);
    }
  </script>
