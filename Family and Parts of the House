        <!-- Four Rooms Layout again for Level 3 items -->
        <div class="w-2/3 h-full grid grid-cols-2 grid-rows-2 gap-2 p-1 bg-teal-100 rounded-2xl border-4 border-teal-400 overflow-hidden relative shadow-inner">
          
          <!-- Kitchen Room Dropzone -->
          <div id="zone-kitchen3" class="dropzone bg-rose-50 border-4 border-dashed border-rose-300 rounded-xl relative flex flex-col items-center justify-center p-2" data-filled="false">
            <span class="bg-rose-400 text-white px-2 py-0.5 rounded-full text-xs font-bold absolute top-1 left-1">Kitchen</span>
            <span class="text-xs text-rose-500 font-bold text-center pointer-events-none">Match the cooking tool!</span>
