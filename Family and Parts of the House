<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title>My Family and My House - Kindergarten Puzzle Game</title>
  <!-- Tailwind CSS -->
  <script src="https://cdn.tailwindcss.com"></script>
  <!-- Google Fonts for friendly rounded typography -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fredoka:wght@400;600;700&display=swap" rel="stylesheet">
  <style>
    body {
      font-family: 'Fredoka', system-ui, -apple-system, sans-serif;
      touch-action: none;
      background: radial-gradient(circle, #eefcff 0%, #d2f4ff 100%);
      overflow: hidden;
    }
    /* Fixed 16:9 responsive wrapper */
    .game-container {
      aspect-ratio: 16 / 9;
      width: 100%;
      max-width: 1100px;
      max-height: 100vh;
      position: relative;
    }
    .draggable {
      touch-action: none;
      cursor: grab;
      transition: transform 0.15s ease, box-shadow 0.15s ease;
    }
    .draggable:active {
      cursor: grabbing;
      transform: scale(1.1);
      z-index: 50;
    }
    .dropzone-active {
      filter: drop-shadow(0 0 12px rgba(251, 191, 36, 0.8));
    }
    /* Custom animation for matching feedback */
    @keyframes bounce-pop {
      0% { transform: scale(1); }
      50% { transform: scale(1.2); }
      100% { transform: scale(1); }
    }
    .pop-success {
      animation: bounce-pop 0.5s ease-out forwards;
    }
    @keyframes shake-error {
      0%, 100% { transform: translateX(0); }
      20%, 60% { transform: translateX(-8px); }
      40%, 80% { transform: translateX(8px); }
    }
    .shake-fail {
      animation: shake-error 0.4s ease-out;
    }
    /* Prevent image/svg blue highlights on drag */
    img, svg {
      user-select: none;
      -webkit-user-drag: none;
    }
  </style>
</head>
<body class="h-screen w-screen flex items-center justify-center p-2 md:p-4">

  <!-- Main Game Container preserving 16:9 -->
  <div id="gameWindow" class="game-container bg-white rounded-3xl shadow-2xl border-8 border-yellow-300 flex flex-col justify-between overflow-hidden relative select-none">
    
    <!-- Top HUD Navigation Bar -->
    <header class="bg-gradient-to-r from-pink-400 via-yellow-300 to-green-400 p-3 flex justify-between items-center border-b-4 border-yellow-200">
      <!-- Title & Speaker -->
      <div class="flex items-center space-x-3">
        <button onclick="speakInstructions()" class="bg-white p-2 rounded-full shadow hover:bg-yellow-100 transition transform hover:scale-105" title="Hear Voice Instructions">
          <!-- Speaker Icon -->
          <svg class="w-7 h-7 text-pink-500 animate-pulse" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15.536 8.464a5 5 0 010 7.072M18.364 5.636a9 9 0 010 12.728M12 18.75V5.25L7.75 9.5H4.5v5h3.25L12 18.75z" />
          </svg>
        </button>
        <span class="text-xl md:text-3xl font-extrabold text-purple-800 tracking-wide drop-shadow-sm">My Family & My House</span>
      </div>

      <!-- Current Goal Message Bubbles -->
      <div id="hintBubble" class="hidden md:flex bg-white px-4 py-1.5 rounded-full border-2 border-purple-300 text-purple-700 font-semibold text-sm shadow-inner animate-bounce">
        Let's assemble the house elements!
      </div>

      <!-- Controls & Points Info -->
      <div class="flex items-center space-x-3">
        <!-- Stars Count -->
        <div class="bg-white/80 px-3 py-1 rounded-full flex items-center space-x-1.5 font-bold text-yellow-600 border border-yellow-300 shadow-sm">
          <svg class="w-6 h-6 fill-current text-yellow-400" viewBox="0 0 24 24">
            <path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/>
          </svg>
          <span id="scoreDisplay" class="text-lg md:text-xl">0</span>
        </div>

        <!-- Music Toggle -->
        <button id="musicToggle" class="bg-indigo-100 p-2 rounded-full hover:bg-indigo-200 border border-indigo-300 transition" onclick="toggleMusic()">
          <!-- Music Note SVG -->
          <svg id="musicOnIcon" class="w-6 h-6 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3" />
          </svg>
          <svg id="musicOffIcon" class="w-6 h-6 text-red-500 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636" />
          </svg>
        </button>
      </div>
    </header>

    <!-- Main Dynamic Level Playboard -->
    <main class="flex-grow flex p-3 md:p-6 relative overflow-hidden" id="levelContainer">
      <!-- LEVEL 1: BUILD THE HOUSE -->
      <div id="level1" class="w-full h-full flex flex-row items-center justify-between space-x-4">
        
        <!-- Drag Item Dock (Left Side) -->
        <div class="w-1/3 bg-orange-50 border-4 border-dashed border-orange-300 rounded-2xl p-4 flex flex-col justify-around items-center h-full shadow-inner">
          <h3 class="text-orange-600 font-extrabold text-base md:text-lg mb-2 text-center">Grab House Parts!</h3>
          
          <div class="flex flex-wrap gap-4 items-center justify-center w-full">
            <!-- Roof Card -->
            <div id="drag-roof" class="draggable bg-white p-2 rounded-xl shadow-md border-2 border-orange-200 flex flex-col items-center justify-center w-24 h-24 md:w-32 md:h-32" data-target="zone-roof">
              <svg class="w-16 h-12 md:w-20 md:h-16" viewBox="0 0 100 60">
                <polygon points="50,5 5,55 95,55" fill="#f87171" stroke="#dc2626" stroke-width="3" />
                <polygon points="50,15 20,50 80,50" fill="#ef4444" />
              </svg>
              <span class="text-xs md:text-sm font-bold text-gray-700 mt-1">Roof</span>
            </div>

            <!-- Walls Card -->
            <div id="drag-walls" class="draggable bg-white p-2 rounded-xl shadow-md border-2 border-orange-200 flex flex-col items-center justify-center w-24 h-24 md:w-32 md:h-32" data-target="zone-walls">
              <svg class="w-12 h-12 md:w-16 md:h-16" viewBox="0 0 100 100">
                <rect x="10" y="10" width="80" height="80" fill="#fef08a" stroke="#ca8a04" stroke-width="4" rx="5" />
                <line x1="10" y1="50" x2="90" y2="50" stroke="#facc15" stroke-width="2" />
                <line x1="50" y1="10" x2="50" y2="90" stroke="#facc15" stroke-width="2" />
              </svg>
              <span class="text-xs md:text-sm font-bold text-gray-700 mt-1">Walls</span>
            </div>

            <!-- Door Card -->
            <div id="drag-door" class="draggable bg-white p-2 rounded-xl shadow-md border-2 border-orange-200 flex flex-col items-center justify-center w-24 h-24 md:w-32 md:h-32" data-target="zone-door">
              <svg class="w-10 h-14 md:w-14 md:h-20" viewBox="0 0 60 100">
                <rect x="5" y="5" width="50" height="90" fill="#b45309" stroke="#78350f" stroke-width="4" rx="3" />
                <circle cx="45" cy="50" r="5" fill="#fbbf24" />
              </svg>
              <span class="text-xs md:text-sm font-bold text-gray-700 mt-1">Door</span>
            </div>

            <!-- Window Card -->
            <div id="drag-window" class="draggable bg-white p-2 rounded-xl shadow-md border-2 border-orange-200 flex flex-col items-center justify-center w-24 h-24 md:w-32 md:h-32" data-target="zone-window">
              <svg class="w-12 h-12 md:w-16 md:h-16" viewBox="0 0 80 80">
                <rect x="5" y="5" width="70" height="70" fill="#60a5fa" stroke="#2563eb" stroke-width="4" rx="4" />
                <line x1="40" y1="5" x2="40" y2="75" stroke="#ffffff" stroke-width="3" />
                <line x1="5" y1="40" x2="75" y2="40" stroke="#ffffff" stroke-width="3" />
              </svg>
              <span class="text-xs md:text-sm font-bold text-gray-700 mt-1">Window</span>
            </div>
          </div>

        </div>

        <!-- Silhouette Target Canvas (Right Side) -->
        <div class="w-2/3 h-full flex items-center justify-center relative bg-sky-100 rounded-2xl border-4 border-sky-300 overflow-hidden shadow-inner">
          <!-- Sky Background Details -->
          <div class="absolute top-4 left-6 bg-white opacity-80 rounded-full w-20 h-8"></div>
          <div class="absolute top-10 right-10 bg-white opacity-80 rounded-full w-24 h-10"></div>
          
          <!-- Silhouette Layout of House -->
          <div class="relative w-full h-full flex flex-col justify-end items-center pb-8">
            <!-- Roof Shadow Dropzone -->
            <div id="zone-roof" class="dropzone absolute bottom-36 w-60 h-32 flex items-center justify-center border-4 border-dashed border-gray-400 bg-gray-200/50 rounded-lg" data-filled="false" style="clip-path: polygon(50% 0%, 0% 100%, 100% 100%);">
              <span class="text-gray-600 font-bold text-sm pointer-events-none">Drop Roof Here</span>
            </div>

            <!-- Walls Shadow Dropzone -->
            <div id="zone-walls" class="dropzone absolute bottom-6 w-52 h-36 flex items-center justify-center border-4 border-dashed border-gray-400 bg-gray-200/50 rounded-lg" data-filled="false">
              <span class="text-gray-600 font-bold text-sm pointer-events-none">Drop Walls Here</span>
            </div>

            <!-- Window Shadow Dropzone -->
            <div id="zone-window" class="dropzone absolute bottom-16 left-[calc(50%-85px)] w-16 h-16 flex items-center justify-center border-4 border-dashed border-gray-400 bg-gray-200/50 rounded-lg z-10" data-filled="false">
              <span class="text-gray-500 font-bold text-2xs text-center pointer-events-none">Drop Window</span>
            </div>

            <!-- Door Shadow Dropzone -->
            <div id="zone-door" class="dropzone absolute bottom-6 right-[calc(50%-85px)] w-14 h-24 flex items-center justify-center border-4 border-dashed border-gray-400 bg-gray-200/50 rounded-lg z-10" data-filled="false">
              <span class="text-gray-500 font-bold text-2xs text-center pointer-events-none">Drop Door</span>
            </div>
          </div>
        </div>

      </div>

      <!-- LEVEL 2: MEET THE FAMILY (Hidden by default) -->
      <div id="level2" class="w-full h-full hidden flex-row items-center justify-between space-x-4">
        
        <!-- Drag Item Dock (Left Side) -->
        <div class="w-1/3 bg-pink-50 border-4 border-dashed border-pink-300 rounded-2xl p-4 flex flex-col justify-around items-center h-full shadow-inner">
          <h3 class="text-pink-600 font-extrabold text-base md:text-lg mb-1 text-center">Drag to their Room!</h3>
          
          <div class="flex flex-wrap gap-2 md:gap-4 items-center justify-center w-full">
            <!-- Mom -->
            <div id="drag-mom" class="draggable bg-white p-2 rounded-xl shadow-md border-2 border-pink-200 flex flex-col items-center justify-center w-20 h-24 md:w-24 md:h-28" data-target="zone-kitchen">
              <!-- Cute Mom SVG -->
              <svg class="w-12 h-12 md:w-14 md:h-14" viewBox="0 0 100 100">
                <circle cx="50" cy="50" r="35" fill="#fbcfe8" stroke="#db2777" stroke-width="2"/>
                <!-- Hair buns -->
                <circle cx="25" cy="25" r="12" fill="#4a044e" />
                <circle cx="75" cy="25" r="12" fill="#4a044e" />
                <circle cx="50" cy="45" r="28" fill="#4a044e" />
                <circle cx="50" cy="52" r="22" fill="#fbcfe8" />
                <!-- Eyes -->
                <circle cx="42" cy="48" r="3" fill="#1e1b4b" />
                <circle cx="58" cy="48" r="3" fill="#1e1b4b" />
                <!-- Smile -->
                <path d="M 44 58 Q 50 64 56 58" stroke="#db2777" stroke-width="3" fill="none" stroke-linecap="round" />
                <!-- Apron -->
                <path d="M 38 72 L 62 72 L 58 85 L 42 85 Z" fill="#ec4899" />
              </svg>
              <span class="text-xs font-bold text-gray-700 mt-1">Mom</span>
            </div>

            <!-- Dad -->
            <div id="drag-dad" class="draggable bg-white p-2 rounded-xl shadow-md border-2 border-pink-200 flex flex-col items-center justify-center w-20 h-24 md:w-24 md:h-28" data-target="zone-living">
              <!-- Cute Dad SVG -->
              <svg class="w-12 h-12 md:w-14 md:h-14" viewBox="0 0 100 100">
                <circle cx="50" cy="50" r="35" fill="#ffedd5" stroke="#ea580c" stroke-width="2" />
                <!-- Hair -->
                <path d="M 20 40 Q 50 15 80 40 Q 50 25 20 40" fill="#451a03" />
                <!-- Glasses -->
                <rect x="30" y="42" width="16" height="12" rx="2" fill="none" stroke="#ea580c" stroke-width="3" />
                <rect x="54" y="42" width="16" height="12" rx="2" fill="none" stroke="#ea580c" stroke-width="3" />
                <line x1="46" y1="48" x2="54" y2="48" stroke="#ea580c" stroke-width="3" />
                <!-- Eyes inside glasses -->
                <circle cx="38" cy="48" r="2.5" fill="#111" />
                <circle cx="62" cy="48" r="2.5" fill="#111" />
                <!-- Smile -->
                <path d="M 43 62 Q 50 68 57 62" stroke="#ea580c" stroke-width="3" fill="none" stroke-linecap="round" />
              </svg>
              <span class="text-xs font-bold text-gray-700 mt-1">Dad</span>
            </div>

            <!-- Sister -->
            <div id="drag-sister" class="draggable bg-white p-2 rounded-xl shadow-md border-2 border-pink-200 flex flex-col items-center justify-center w-20 h-24 md:w-24 md:h-28" data-target="zone-bedroom">
              <!-- Cute Sister SVG -->
              <svg class="w-12 h-12 md:w-14 md:h-14" viewBox="0 0 100 100">
                <circle cx="50" cy="50" r="35" fill="#fef3c7" stroke="#b45309" stroke-width="2" />
                <!-- Hair Pigtails -->
                <circle cx="15" cy="35" r="12" fill="#b45309" />
                <circle cx="85" cy="35" r="12" fill="#b45309" />
                <path d="M 22 45 Q 50 25 78 45" fill="#d97706" />
                <!-- Eyes -->
                <circle cx="42" cy="50" r="3" fill="#111" />
                <circle cx="58" cy="50" r="3" fill="#111" />
                <!-- Rosy Cheeks -->
                <circle cx="35" cy="58" r="4" fill="#f43f5e" opacity="0.5" />
                <circle cx="65" cy="58" r="4" fill="#f43f5e" opacity="0.5" />
                <!-- Smile -->
                <path d="M 45 60 Q 50 66 55 60" stroke="#b45309" stroke-width="2.5" fill="none" stroke-linecap="round" />
              </svg>
              <span class="text-xs font-bold text-gray-700 mt-1">Sister</span>
            </div>

            <!-- Puppy -->
            <div id="drag-puppy" class="draggable bg-white p-2 rounded-xl shadow-md border-2 border-pink-200 flex flex-col items-center justify-center w-20 h-24 md:w-24 md:h-28" data-target="zone-garden">
              <!-- Cute Puppy SVG -->
              <svg class="w-12 h-12 md:w-14 md:h-14" viewBox="0 0 100 100">
                <circle cx="50" cy="50" r="35" fill="#f5e0c3" stroke="#78350f" stroke-width="2" />
                <!-- Ears -->
                <ellipse cx="20" cy="40" rx="10" ry="20" fill="#78350f" transform="rotate(15 20 40)"/>
                <ellipse cx="80" cy="40" rx="10" ry="20" fill="#78350f" transform="rotate(-15 80 40)"/>
                <!-- Eyes -->
                <circle cx="40" cy="48" r="4.5" fill="#111" />
                <circle cx="60" cy="48" r="4.5" fill="#111" />
                <!-- Nose -->
                <polygon points="46,56 54,56 50,61" fill="#78350f" />
                <!-- Tongue -->
                <path d="M 47 64 Q 50 72 53 64 Z" fill="#f43f5e" />
              </svg>
              <span class="text-xs font-bold text-gray-700 mt-1">Puppy</span>
            </div>
          </div>
        </div>

        <!-- Four-Room House Playboard (Right Side) -->
        <div class="w-2/3 h-full grid grid-cols-2 grid-rows-2 gap-2 p-1 bg-yellow-100 rounded-2xl border-4 border-yellow-400 overflow-hidden relative shadow-inner">
          
          <!-- Kitchen Room Dropzone -->
          <div id="zone-kitchen" class="dropzone bg-rose-50 border-4 border-dashed border-rose-300 rounded-xl relative flex flex-col items-center justify-between p-2" data-filled="false">
            <span class="bg-rose-400 text-white px-2 py-0.5 rounded-full text-xs font-bold absolute top-1 left-1">Kitchen</span>
            <div class="absolute bottom-2 right-2 opacity-30">
              <!-- Cooker/Oven silhouette -->
              <svg class="w-12 h-12" fill="currentColor" viewBox="0 0 24 24"><path d="M19 4H5c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm-9 14H6v-6h4v6zm8 0h-6v-2h6v2zm0-4h-6v-2h6v2z"/></svg>
            </div>
            <span class="text-xs text-rose-500 font-bold m-auto text-center pointer-events-none">Mom is hungry!<br>Where is the kitchen?</span>
          </div>

          <!-- Living Room Dropzone -->
          <div id="zone-living" class="dropzone bg-blue-50 border-4 border-dashed border-blue-300 rounded-xl relative flex flex-col items-center justify-between p-2" data-filled="false">
            <span class="bg-blue-400 text-white px-2 py-0.5 rounded-full text-xs font-bold absolute top-1 left-1">Living Room</span>
            <div class="absolute bottom-2 right-2 opacity-30">
              <!-- Armchair/TV silhouette -->
              <svg class="w-12 h-12" fill="currentColor" viewBox="0 0 24 24"><path d="M21 3H3c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h5v2h8v-2h5c1.1 0 1.9-.9 1.9-2L23 5c0-1.1-.9-2-2-2zm-2 12H5V5h14v10z"/></svg>
            </div>
            <span class="text-xs text-blue-500 font-bold m-auto text-center pointer-events-none">Dad wants to sit on the cozy sofa!</span>
          </div>

          <!-- Bedroom Dropzone -->
          <div id="zone-bedroom" class="dropzone bg-indigo-50 border-4 border-dashed border-indigo-300 rounded-xl relative flex flex-col items-center justify-between p-2" data-filled="false">
            <span class="bg-indigo-400 text-white px-2 py-0.5 rounded-full text-xs font-bold absolute top-1 left-1">Bedroom</span>
            <div class="absolute bottom-2 right-2 opacity-30">
              <!-- Bed silhouette -->
              <svg class="w-12 h-12" fill="currentColor" viewBox="0 0 24 24"><path d="M20 10V7c0-1.1-.9-2-2-2H6c-1.1 0-2 .9-2 2v3c-1.1 0-2 .9-2 2v5h1.33L4 19h1.33l.67-2h12l.67 2H20l.67-2H22v-5c0-1.1-.9-2-2-2zm-9 0H6V7h5v3zm7 0h-5V7h5v3z"/></svg>
            </div>
            <span class="text-xs text-indigo-500 font-bold m-auto text-center pointer-events-none">Sister is sleepy and loves her toys!</span>
          </div>

          <!-- Garden Dropzone -->
          <div id="zone-garden" class="dropzone bg-emerald-50 border-4 border-dashed border-emerald-300 rounded-xl relative flex flex-col items-center justify-between p-2" data-filled="false">
            <span class="bg-emerald-400 text-white px-2 py-0.5 rounded-full text-xs font-bold absolute top-1 left-1">Garden</span>
            <div class="absolute bottom-2 right-2 opacity-30">
              <!-- Flower/Tree silhouette -->
              <svg class="w-12 h-12" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.53c-.26-.81-1-1.4-1.9-1.4h-1v-3c0-.55-.45-1-1-1h-6v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"/></svg>
            </div>
            <span class="text-xs text-emerald-500 font-bold m-auto text-center pointer-events-none">Puppy wants to run on the green grass!</span>
          </div>

        </div>

      </div>

      <!-- LEVEL 3: HOUSEHOLD ITEMS MATCH (Hidden by default) -->
      <div id="level3" class="w-full h-full hidden flex-row items-center justify-between space-x-4">
        
        <!-- Drag Item Dock (Left Side) -->
        <div class="w-1/3 bg-teal-50 border-4 border-dashed border-teal-300 rounded-2xl p-4 flex flex-col justify-around items-center h-full shadow-inner">
          <h3 class="text-teal-600 font-extrabold text-base md:text-lg mb-1 text-center">Where do they belong?</h3>
          
          <div class="flex flex-wrap gap-2 md:gap-4 items-center justify-center w-full">
            <!-- Bed -->
            <div id="drag-bed" class="draggable bg-white p-2 rounded-xl shadow-md border-2 border-teal-200 flex flex-col items-center justify-center w-20 h-24 md:w-24 md:h-28" data-target="zone-bedroom3">
              <svg class="w-12 h-12" viewBox="0 0 100 100">
                <rect x="10" y="40" width="80" height="40" fill="#a7f3d0" stroke="#059669" stroke-width="3" rx="5" />
                <rect x="15" y="25" width="30" height="20" fill="#ffffff" stroke="#059669" stroke-width="2" rx="3" />
                <rect x="50" y="25" width="30" height="20" fill="#ffffff" stroke="#059669" stroke-width="2" rx="3" />
                <line x1="10" y1="65" x2="10" y2="90" stroke="#059669" stroke-width="5" />
                <line x1="90" y1="65" x2="90" y2="90" stroke="#059669" stroke-width="5" />
              </svg>
              <span class="text-xs font-bold text-gray-700 mt-1">Bed</span>
            </div>

            <!-- Frying Pan -->
            <div id="drag-pan" class="draggable bg-white p-2 rounded-xl shadow-md border-2 border-teal-200 flex flex-col items-center justify-center w-20 h-24 md:w-24 md:h-28" data-target="zone-kitchen3">
              <svg class="w-12 h-12" viewBox="0 0 100 100">
                <ellipse cx="40" cy="55" rx="25" ry="18" fill="#4b5563" stroke="#1f2937" stroke-width="3"/>
                <line x1="60" y1="45" x2="90" y2="20" stroke="#1f2937" stroke-width="6" stroke-linecap="round"/>
                <ellipse cx="35" cy="52" rx="15" ry="10" fill="#9ca3af" />
              </svg>
              <span class="text-xs font-bold text-gray-700 mt-1">Frying Pan</span>
            </div>

            <!-- Teddy Bear -->
            <div id="drag-teddy" class="draggable bg-white p-2 rounded-xl shadow-md border-2 border-teal-200 flex flex-col items-center justify-center w-20 h-24 md:w-24 md:h-28" data-target="zone-living3">
              <svg class="w-12 h-12" viewBox="0 0 100 100">
                <!-- Head & Ears -->
                <circle cx="50" cy="45" r="22" fill="#b45309" stroke="#78350f" stroke-width="2"/>
                <circle cx="32" cy="27" r="8" fill="#b45309" />
