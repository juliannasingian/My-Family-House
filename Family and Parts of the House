          <!-- Living Room Dropzone -->
          <div id="zone-living3" class="dropzone bg-blue-50 border-4 border-dashed border-blue-300 rounded-xl relative flex flex-col items-center justify-center p-2" data-filled="false">
            <span class="bg-blue-400 text-white px-2 py-0.5 rounded-full text-xs font-bold absolute top-1 left-1">Living Room</span>
            <span class="text-xs text-blue-500 font-bold text-center pointer-events-none">Match the comfy toy!</span>
