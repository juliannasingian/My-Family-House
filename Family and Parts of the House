            <!-- Watering Can -->
            <div id="drag-pot" class="draggable bg-white p-2 rounded-xl shadow-md border-2 border-teal-200 flex flex-col items-center justify-center w-20 h-24 md:w-24 md:h-28" data-target="zone-garden3">
              <svg class="w-12 h-12" viewBox="0 0 100 100">
                <rect x="25" y="35" width="40" height="40" fill="#3b82f6" stroke="#1d4ed8" stroke-width="3" rx="5" />
                <!-- Spout -->
